# .env.example — Plantilla de configuración del bot CSV CTV.
#
# Cómo usar: copiá este archivo a `.env` y completá los valores reales.
# El `.env` real está gitignored (nunca lo subas). Pasalo entre máquinas por
# canal seguro (1Password, Bitwarden, gestor del equipo).
#
#   cp .env.example .env
#   # editá .env con los valores reales
#
# ─────────────────────────────────────────────────────────────────────────────
# Jira (id.atlassian.net → Security → API tokens)
# ─────────────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://seedtag.atlassian.net
JIRA_EMAIL=tu-email@seedtag.com
JIRA_API_TOKEN=<API token de Atlassian>
JIRA_PROJECT_KEY=SDS

# ─────────────────────────────────────────────────────────────────────────────
# Slack (api.slack.com/apps → app "CSV CTV"; scopes: channels:history,
# chat:write, reactions:read)
# ─────────────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=csv-tickets
SLACK_CHANNEL_ID=C0B2ATE790B

# ─────────────────────────────────────────────────────────────────────────────
# Studio Seedtag — JWT del bot `design_automations@seedtag.com`.
# Se extrae manualmente desde DevTools → Application → Cookies → `seedtag_jwt`
# en studio.seedtag.com (logueado como el bot). El bot lo rota solo en cada
# llamada (sidecar `.studio_jwt` en TMP_DIR). El JWT inicial del .env solo se
# usa la primera vez si el sidecar no existe.
# ─────────────────────────────────────────────────────────────────────────────
STUDIO_JWT_COOKIE=eyJ...
STUDIO_EMAIL=design_automations@seedtag.com
STUDIO_PASSWORD=<solo si necesitás fallback manual>

# ─────────────────────────────────────────────────────────────────────────────
# Encoding (CTV — el flujo Open Web calcula bitrate por target ~4MB y NO usa
# estos valores)
# ─────────────────────────────────────────────────────────────────────────────
BITRATE_SHORT=30
BITRATE_LONG=15
DURATION_THRESHOLD=30

# ─────────────────────────────────────────────────────────────────────────────
# Paths (usar rutas absolutas a TU usuario)
# ─────────────────────────────────────────────────────────────────────────────
TMP_DIR=/Users/<tu_usuario>/Documents/CSV_automations/tmp
LOGS_DIR=/Users/<tu_usuario>/Documents/CSV_automations/logs

# ─────────────────────────────────────────────────────────────────────────────
# Dashboard (opcionales; defaults: 127.0.0.1:8787)
# ─────────────────────────────────────────────────────────────────────────────
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8787

# ─────────────────────────────────────────────────────────────────────────────
# Google Cloud Storage (opcional — se activa al setear GCS_BUCKET; inerte si
# vacío. Se usa cuando se migre a GCP para subir el .mp4 full y poner link
# permanente en el ticket.)
# ─────────────────────────────────────────────────────────────────────────────
# GCS_BUCKET=
# GCS_PREFIX=ctv
# GCS_PUBLIC=true
