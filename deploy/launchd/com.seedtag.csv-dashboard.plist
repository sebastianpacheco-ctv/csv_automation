<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.seedtag.csv-dashboard</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/sebastianpacheco/csv-automation/venv/bin/python3</string>
        <string>/Users/sebastianpacheco/csv-automation/src/dashboard.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/sebastianpacheco/csv-automation</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <!-- Servidor web: siempre arriba. Si sale (por lo que sea) se relanza. -->
    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/sebastianpacheco/csv-automation/logs/dashboard-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/sebastianpacheco/csv-automation/logs/dashboard-stderr.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
